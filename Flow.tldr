    {
      "typeName": "shape",
      "id": "shape:6a3a050a",
      "type": "geo",
      "x": 60,
      "y": 2340,
      "rotation": 0,
      "isLocked": false,
      "opacity": 1,
      "meta": {},
      "props": {
        "geo": "rectangle",
        "w": 680,
        "h": 180,
        "text": "Loan range:          Rs. 5,000 \u2013 Rs. 20,000\nTenures:             3 / 6 / 9 / 12 months\nInterest rate:       12% per annum (flat)\nProcessing fee:      5% of principal  +  18% GST on that fee\nNet disbursement:    principal  \u2212  (processing fee + GST)\nReferences:          2 required, both OTP-verified\nPayment modes:       BANK  |  UPI\nEligibility:         credit_score >= 650  (NOT FOIR)",
        "color": "black",
        "fill": "none",
        "dash": "draw",
        "size": "s",
        "font": "mono",
        "align": "start",
        "verticalAlign": "middle",

    {
      "typeName": "shape",
      "id": "shape:116761b3",
      "type": "geo",
      "x": 60,
      "y": 2592,
      "rotation": 0,
      "isLocked": false,
      "opacity": 1,
      "meta": {},
      "props": {
        "geo": "rectangle",
        "w": 680,
        "h": 210,
        "text": "\u2705  Eligibility uses credit_score (\u2265650) \u2014 FOIR is NOT used\n\u2705  approved_amount comes from the eligibility record \u2014 borrower cannot set it\n\u2705  Steps must be done in order \u2014 step_tracker enforces the sequence\n\u2705  Both references must OTP-verify before Declaration can be submitted\n\u2705  App is locked after /submit \u2014 no edits allowed\n\u2705  reference_number and all financial fields set at submit time only\n\u2705  Lender must be active=True and blocked=False to pick an app\n\u2705  Row-level DB lock \u2014 two lenders cannot claim the same app\n\u2705  Lender can only approve/reject apps they personally picked\n\u26a0\ufe0f  /purpose and /references use form-data \u2014 NOT JSON",
        "color": "black",
        "fill": "none",
        "dash": "draw",
        "size": "s",
        "font": "mono",
        "align": "start",
        "verticalAlign": "middle",
        "growY": 0,

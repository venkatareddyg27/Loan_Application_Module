        "w": 680,
        "h": 60,
        "text": "14. GET   /admin/disbursement/{application_id}\n     \u2190 { approved_amount, processing_fee, gst_amount, net_disbursement_amount }",
        "color": "red",
        "fill": "none",
        "dash": "draw",

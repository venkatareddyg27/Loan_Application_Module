      "x": 60,
      "y": 40,
      "rotation": 0,
      "isLocked": false,
      "opacity": 1,
      "meta": {},
      "props": {
        "text": "Loan Application API \u2014 Complete Flow",
        "color": "violet",
        "size": "xl",
        "font": "sans",
        "align": "middle",
        "w": 680,
        "autoSize": false,
        "scale": 1
      },
      "parentId": "page:page",
      "index": "a1"
    },
    {
      "typeName": "shape",
      "id": "shape:0f42079a",
      "type": "geo",
      "x": 60,
      "y": 110,
      "rotation": 0,
      "isLocked": false,
      "opacity": 1,
      "meta": {},
      "props": {
        "geo": "rectangle",
        "w": 680,
        "h": 44,
        "text": "  ELIGIBILITY CHECK",
        "color": "violet",
        "fill": "semi",
        "dash": "draw",
        "size": "m",
        "font": "sans",
        "align": "start",
        "verticalAlign": "middle",
        "growY": 0,
        "url": "",
        "labelColor": "violet"
      },
      "parentId": "page:page",
      "index": "a2"
    },
    {
      "typeName": "shape",
      "id": "shape:c44d743d",
      "type": "geo",
      "x": 60,
      "y": 166,
      "rotation": 0,
      "isLocked": false,
      "opacity": 1,
      "meta": {},
      "props": {
        "geo": "rectangle",
        "w": 680,
        "h": 74,
        "text": "1.  POST  /loan/eligibility/check\n     body: { user_profile_id, credit_score }\n     \u2190 { eligibility_id, status: ELIGIBLE/REJECTED, max_amount }\n     \u2717  credit_score < 650  \u2192  REJECTED",
        "color": "green",
        "fill": "none",
        "dash": "draw",
        "size": "s",
        "font": "mono",
        "align": "start",
        "verticalAlign": "middle",
        "growY": 0,
        "url": "",
        "labelColor": "black"
      },
      "parentId": "page:page",
      "index": "a3"
    },
    {
      "typeName": "shape",
      "id": "shape:92548384",
      "type": "geo",
      "x": 60,
      "y": 264,
      "rotation": 0,
      "isLocked": false,
      "opacity": 1,
      "meta": {},
      "props": {
        "geo": "rectangle",
        "w": 680,
        "h": 44,
        "text": "  APPLICATION",
        "color": "blue",
        "fill": "semi",
        "dash": "draw",
        "size": "m",
        "font": "sans",
        "align": "start",
        "verticalAlign": "middle",
        "growY": 0,
        "url": "",
        "labelColor": "blue"
      },
      "parentId": "page:page",
      "index": "a4"
    },
    {
      "typeName": "shape",
      "id": "shape:c962de47",
      "type": "geo",
      "x": 60,
      "y": 320,
      "rotation": 0,
      "isLocked": false,
      "opacity": 1,
      "meta": {},
      "props": {
        "geo": "rectangle",
        "w": 680,
        "h": 74,
        "text": "2.  POST  /loan/application/apply\n     body: { user_profile_id, eligibility_id, tenure_months }\n     \u2190 { application_id, approved_amount, next_step: \"PURPOSE\" }\n     approved_amount  \u2190  from eligibility record (not user input)",
        "color": "blue",
        "fill": "none",
        "dash": "draw",
        "size": "s",
        "font": "mono",
        "align": "start",
        "verticalAlign": "middle",
        "growY": 0,
        "url": "",
        "labelColor": "black"
      },
      "parentId": "page:page",
      "index": "a5"
    },
    {
      "typeName": "shape",
      "id": "shape:6575825e",
      "type": "geo",
      "x": 60,
      "y": 418,
      "rotation": 0,
      "isLocked": false,
      "opacity": 1,
      "meta": {},
      "props": {
        "geo": "rectangle",
        "w": 680,
        "h": 44,
        "text": "  STEP 1 \u00b7 PURPOSE",
        "color": "orange",
        "fill": "semi",
        "dash": "draw",
        "size": "m",
        "font": "sans",
        "align": "start",
        "verticalAlign": "middle",
        "growY": 0,
        "url": "",
        "labelColor": "orange"
      },
      "parentId": "page:page",
      "index": "a6"
    },
    {
      "typeName": "shape",
      "id": "shape:4f444e72",
      "type": "geo",
      "x": 60,
      "y": 474,
      "rotation": 0,
      "isLocked": false,
      "opacity": 1,
      "meta": {},
      "props": {
        "geo": "rectangle",
        "w": 680,
        "h": 74,
        "text": "3.  PUT   /loan/application/{id}/purpose     \u26a0 form-data (NOT JSON)\n     purpose_code:  MEDICAL | EDUCATION | EMERGENCY | PERSONAL\n     purpose_description: free text\n     \u2190 { purpose_code, purpose_description }",
        "color": "orange",
        "fill": "none",
        "dash": "draw",
        "size": "s",
        "font": "mono",
        "align": "start",
        "verticalAlign": "middle",
        "growY": 0,
        "url": "",
        "labelColor": "black"
      },
      "parentId": "page:page",
      "index": "a7"
    },
    {
      "typeName": "shape",
      "id": "shape:342c252f",
      "type": "geo",
      "x": 60,
      "y": 572,
      "rotation": 0,
      "isLocked": false,
      "opacity": 1,
      "meta": {},
      "props": {
        "geo": "rectangle",
        "w": 680,
        "h": 44,
        "text": "  STEP 2 \u00b7 REFERENCES",
        "color": "orange",
        "fill": "semi",
        "dash": "draw",
        "size": "m",
        "font": "sans",
        "align": "start",
        "verticalAlign": "middle",
        "growY": 0,
        "url": "",
        "labelColor": "orange"
      },
      "parentId": "page:page",
      "index": "a8"
    },
    {
      "typeName": "shape",
      "id": "shape:0e302d5a",
      "type": "geo",
      "x": 60,
      "y": 628,
      "rotation": 0,
      "isLocked": false,
      "opacity": 1,
      "meta": {},
      "props": {
        "geo": "rectangle",
        "w": 680,
        "h": 84,
        "text": "4.  PUT   /loan/application/{id}/references     \u26a0 form-data (NOT JSON)\n     ref1_name, ref1_mobile, ref1_relation_type,  ref2_name, ref2_mobile, ref2_relation_type\n     relation:  FRIEND | BROTHER | SISTER | FATHER | MOTHER | SPOUSE | COLLEAGUE\n     \u2190 [{ id, name, mobile, is_verified: false }, ...]",
        "color": "orange",
        "fill": "none",
        "dash": "draw",
        "size": "s",
        "font": "mono",
        "align": "start",
        "verticalAlign": "middle",
        "growY": 0,
        "url": "",
        "labelColor": "black"
      },
      "parentId": "page:page",
      "index": "a9"
    },
    {
      "typeName": "shape",
      "id": "shape:af1f3043",
      "type": "geo",
      "x": 60,
      "y": 736,
      "rotation": 0,
      "isLocked": false,
      "opacity": 1,
      "meta": {},
      "props": {
        "geo": "rectangle",
        "w": 680,
        "h": 44,
        "text": "  STEP 3 \u00b7 OTP VERIFY  (repeat \u00d72 \u2014 one for each reference)",
        "color": "orange",
        "fill": "semi",
        "dash": "draw",
        "size": "m",
        "font": "sans",
        "align": "start",
        "verticalAlign": "middle",
        "growY": 0,
        "url": "",
        "labelColor": "orange"
      },
      "parentId": "page:page",
      "index": "a10"
    },
    {
      "typeName": "shape",
      "id": "shape:ce6a1fb7",
      "type": "geo",
      "x": 60,
      "y": 792,
      "rotation": 0,
      "isLocked": false,
      "opacity": 1,
      "meta": {},
      "props": {
        "geo": "rectangle",
        "w": 680,
        "h": 64,
        "text": "5.  POST  /loan/application/references/send-otp\n     body: { reference_id }\n     \u2190 { message: \"OTP sent\" }",
        "color": "orange",
        "fill": "none",
        "dash": "draw",
        "size": "s",
        "font": "mono",
        "align": "start",
        "verticalAlign": "middle",
        "growY": 0,
        "url": "",
        "labelColor": "black"
      },
      "parentId": "page:page",
      "index": "a11"
    },
    {
      "typeName": "shape",
      "id": "shape:10909183",
      "type": "geo",
      "x": 60,
      "y": 868,
      "rotation": 0,
      "isLocked": false,
      "opacity": 1,
      "meta": {},
      "props": {
        "geo": "rectangle",
        "w": 680,
        "h": 64,
        "text": "6.  POST  /loan/application/references/verify-otp\n     body: { reference_id, otp_code }\n     \u2190 { verified: true, verified_at }",
        "color": "orange",
        "fill": "none",
        "dash": "draw",
        "size": "s",
        "font": "mono",
        "align": "start",
        "verticalAlign": "middle",
        "growY": 0,
        "url": "",
        "labelColor": "black"
      },
      "parentId": "page:page",
      "index": "a12"
    },
    {
      "typeName": "shape",
      "id": "shape:496cb32d",
      "type": "geo",
      "x": 60,
      "y": 956,
      "rotation": 0,
      "isLocked": false,
      "opacity": 1,
      "meta": {},
      "props": {
        "geo": "rectangle",
        "w": 680,
        "h": 44,
        "text": "  STEP 4 \u00b7 DECLARATION",
        "color": "orange",
        "fill": "semi",
        "dash": "draw",
        "size": "m",
        "font": "sans",
        "align": "start",
        "verticalAlign": "middle",
        "growY": 0,
        "url": "",
        "labelColor": "orange"
      },
      "parentId": "page:page",
      "index": "a13"
    },
    {
      "typeName": "shape",
      "id": "shape:f7dbcd19",
      "type": "geo",
      "x": 60,
      "y": 1012,
      "rotation": 0,
      "isLocked": false,
      "opacity": 1,
      "meta": {},
      "props": {
        "geo": "rectangle",
        "w": 680,
        "h": 84,
        "text": "7.  PUT   /loan/application/{id}/declaration\n     body: { agreed_terms, consent_credit_check, consent_data_sharing,\n              has_existing_loans, has_credit_card, has_default_history,\n              terms_version, privacy_policy_version }\n     \u2190 { consent_timestamp }",
        "color": "orange",
        "fill": "none",
        "dash": "draw",
        "size": "s",
        "font": "mono",
        "align": "start",
        "verticalAlign": "middle",
        "growY": 0,
        "url": "",
        "labelColor": "black"
      },
      "parentId": "page:page",
      "index": "a14"
    },
    {
      "typeName": "shape",
      "id": "shape:daa6b14d",
      "type": "geo",
      "x": 60,
      "y": 1120,
      "rotation": 0,
      "isLocked": false,
      "opacity": 1,
      "meta": {},
      "props": {
        "geo": "rectangle",
        "w": 680,
        "h": 44,
        "text": "  STEP 5 \u00b7 SUMMARY & SUBMIT",
        "color": "orange",
        "fill": "semi",
        "dash": "draw",
        "size": "m",
        "font": "sans",
        "align": "start",
        "verticalAlign": "middle",
        "growY": 0,
        "url": "",
        "labelColor": "orange"
      },
      "parentId": "page:page",
      "index": "a15"
    },
    {
      "typeName": "shape",
      "id": "shape:f3d7670d",
      "type": "geo",
      "x": 60,
      "y": 1176,
      "rotation": 0,
      "isLocked": false,
      "opacity": 1,
      "meta": {},
      "props": {
        "geo": "rectangle",
        "w": 680,
        "h": 60,
        "text": "8.  GET   /loan/application/{id}/summary\n     \u2190 { loan_details, can_submit: true, pending_steps: [] }",
        "color": "orange",
        "fill": "none",
        "dash": "draw",
        "size": "s",
        "font": "mono",
        "align": "start",
        "verticalAlign": "middle",
        "growY": 0,
        "url": "",
        "labelColor": "black"
      },
      "parentId": "page:page",
      "index": "a16"
    },
    {
      "typeName": "shape",
      "id": "shape:b38c56e0",
      "type": "geo",
      "x": 60,
      "y": 1248,
      "rotation": 0,
      "isLocked": false,
      "opacity": 1,
      "meta": {},
      "props": {
        "geo": "rectangle",
        "w": 680,
        "h": 74,
        "text": "9.  POST  /loan/application/{id}/submit\n     body: { confirm: true }\n     \u2190 { reference_number, expected_decision_time: \"24h\" }\n     status \u2192 SUBMITTED   (app locked, lender_id = null)",
        "color": "orange",
        "fill": "none",
        "dash": "draw",
        "size": "s",
        "font": "mono",
        "align": "start",
        "verticalAlign": "middle",
        "growY": 0,
        "url": "",
        "labelColor": "black"
      },
      "parentId": "page:page",
      "index": "a17"
    },
    {
      "typeName": "shape",
      "id": "shape:004f0af1",
      "type": "text",
      "x": 200,
      "y": 1346,
      "rotation": 0,
      "isLocked": false,
      "opacity": 1,
      "meta": {},
      "props": {
        "text": "\u2193  appears in lender dashboard pool",
        "color": "violet",
        "size": "m",
        "font": "sans",
        "align": "middle",
        "w": 400,
        "autoSize": false,
        "scale": 1
      },
      "parentId": "page:page",
      "index": "a18"
    },
    {
      "typeName": "shape",
      "id": "shape:89c6466c",
      "type": "geo",
      "x": 60,
      "y": 1396,
      "rotation": 0,
      "isLocked": false,
      "opacity": 1,
      "meta": {},
      "props": {
        "geo": "rectangle",
        "w": 680,
        "h": 44,
        "text": "  LENDER DASHBOARD",
        "color": "violet",
        "fill": "semi",
        "dash": "draw",
        "size": "m",
        "font": "sans",
        "align": "start",
        "verticalAlign": "middle",
        "growY": 0,
        "url": "",
        "labelColor": "violet"
      },
      "parentId": "page:page",
      "index": "a19"
    },
    {
      "typeName": "shape",
      "id": "shape:c9d70af8",
      "type": "geo",
      "x": 60,
      "y": 1452,
      "rotation": 0,
      "isLocked": false,
      "opacity": 1,
      "meta": {},
      "props": {
        "geo": "rectangle",
        "w": 680,
        "h": 64,
        "text": "10. GET   /lender/applications\n     returns all SUBMITTED apps where lender_id = null\n     \u2190 [{ application_id, reference_number, approved_amount, tenure_months, status }]",
        "color": "violet",
        "fill": "none",
        "dash": "draw",
        "size": "s",
        "font": "mono",
        "align": "start",
        "verticalAlign": "middle",
        "growY": 0,
        "url": "",
        "labelColor": "black"
      },
      "parentId": "page:page",
      "index": "a20"
    },
    {
      "typeName": "shape",
      "id": "shape:5d734f75",
      "type": "geo",
      "x": 60,
      "y": 1528,
      "rotation": 0,
      "isLocked": false,
      "opacity": 1,
      "meta": {},
      "props": {
        "geo": "rectangle",
        "w": 680,
        "h": 80,
        "text": "11. POST  /lender/pick/{application_id}?lender_id={id}\n     lender must be  is_active=True  and  is_blocked=False\n     row-level lock  (SELECT FOR UPDATE) \u2014 prevents 2 lenders picking same app\n     status \u2192 UNDER_REVIEW   |   lender_id = lender.id",
        "color": "violet",
        "fill": "none",
        "dash": "draw",
        "size": "s",
        "font": "mono",
        "align": "start",
        "verticalAlign": "middle",
        "growY": 0,
        "url": "",
        "labelColor": "black"
      },
      "parentId": "page:page",
      "index": "a21"
    },
    {
      "typeName": "shape",
      "id": "shape:7467c4b0",
      "type": "geo",
      "x": 60,
      "y": 1620,
      "rotation": 0,
      "isLocked": false,
      "opacity": 1,
      "meta": {},
      "props": {
        "geo": "rectangle",
        "w": 680,
        "h": 60,
        "text": "12. GET   /lender/my-applications/{lender_id}\n     \u2190 [{ application_id, reference_number, status, ... }]",
        "color": "violet",
        "fill": "none",
        "dash": "draw",
        "size": "s",
        "font": "mono",
        "align": "start",
        "verticalAlign": "middle",
        "growY": 0,
        "url": "",
        "labelColor": "black"
      },
      "parentId": "page:page",
      "index": "a22"
    },
    {
      "typeName": "shape",
      "id": "shape:d884b5bf",
      "type": "geo",
      "x": 60,
      "y": 1704,
      "rotation": 0,
      "isLocked": false,
      "opacity": 1,
      "meta": {},
      "props": {
        "geo": "rectangle",
        "w": 334,
        "h": 94,
        "text": "13a. POST  /lender/approve/{id}\n      ?lender_id={id}\n      must be UNDER_REVIEW\n      must be same lender who picked\n      status \u2192 APPROVED\n      \u2190 { message: \"Approved\" }",
        "color": "green",
        "fill": "none",
        "dash": "draw",
        "size": "s",
        "font": "mono",
        "align": "start",
        "verticalAlign": "middle",
        "growY": 0,
        "url": "",
        "labelColor": "black"
      },
      "parentId": "page:page",
      "index": "a23"
    },
    {
      "typeName": "shape",
      "id": "shape:0f9b9677",
      "type": "geo",
      "x": 406,
      "y": 1704,
      "rotation": 0,
      "isLocked": false,
      "opacity": 1,
      "meta": {},
      "props": {
        "geo": "rectangle",
        "w": 334,
        "h": 94,
        "text": "13b. POST  /lender/reject/{id}\n      ?lender_id={id}\n      &rejection_reason=...\n      must be UNDER_REVIEW\n      rejection_reason required\n      status \u2192 REJECTED  \u2717 terminal",
        "color": "red",
        "fill": "none",
        "dash": "draw",
        "size": "s",
        "font": "mono",
        "align": "start",
        "verticalAlign": "middle",
        "growY": 0,
        "url": "",
        "labelColor": "black"
      },
      "parentId": "page:page",
      "index": "a24"
    },
    {
      "typeName": "shape",
      "id": "shape:adbf2c95",
      "type": "text",
      "x": 200,
      "y": 1822,
      "rotation": 0,
      "isLocked": false,
      "opacity": 1,
      "meta": {},
      "props": {
        "text": "\u2193  only if status = APPROVED",
        "color": "green",
        "size": "m",
        "font": "sans",
        "align": "middle",
        "w": 400,
        "autoSize": false,
        "scale": 1
      },
